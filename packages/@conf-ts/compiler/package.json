{
  "name": "@conf-ts/compiler",
  "version": "0.0.16",
  "description": "Compiler for conf-ts.",
  "author": {
    "name": "Zhongliang Wang",
    "email": "hello@zhongliang.wang",
    "url": "https://zhongliang.wang"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cryrivers/conf-ts"
  },
  "main": "dist/cjs/index.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/cjs/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./browser": {
      "types": "./dist/cjs/browser.d.ts",
      "import": "./dist/cjs/browser.js",
      "require": "./dist/cjs/browser.js"
    },
    "./internal": {
      "types": "./dist/cjs/internal.d.ts",
      "import": "./dist/cjs/internal.js",
      "require": "./dist/cjs/internal.js"
    }
  },
  "types": "dist/cjs/index.d.ts",
  "scripts": {
    "build": "pnpm run build:cjs",
    "build:cjs": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.cjs.json",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@conf-ts/expr-core": "workspace:*",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^26.1.1",
    "prettier": "^3.9.5",
    "vitest": "^4.1.10"
  }
}
