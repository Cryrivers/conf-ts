{
  "name": "@conf-ts/expression",
  "version": "0.0.8",
  "description": "JavaScript expression parser and evaluator",
  "keywords": [],
  "license": "MIT",
  "author": {
    "name": "Zhongliang Wang",
    "email": "hello@zhongliang.wang",
    "url": "https://zhongliang.wang"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "test": "vitest run --typecheck",
    "format": "prettier --write .",
    "lint:fix": "oxlint --fix",
    "type-check": "tsc --noEmit",
    "build": "tsdown --minify",
    "dev": "tsdown --watch"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@vitest/coverage-v8": "4.1.9",
    "oxlint": "^1.70.0",
    "prettier": "^3.8.4",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
