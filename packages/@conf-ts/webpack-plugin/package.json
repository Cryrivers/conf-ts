{
  "name": "@conf-ts/webpack-plugin",
  "version": "0.0.14",
  "description": "Webpack plugin for conf-ts",
  "author": {
    "name": "Zhongliang Wang",
    "email": "hello@zhongliang.wang",
    "url": "https://zhongliang.wang"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cryrivers/conf-ts"
  },
  "main": "dist/cjs/index.js",
  "types": "dist/cjs/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/cjs/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    },
    "./macro-transform-plugin/typescript": {
      "types": "./dist/cjs/macro-transform-plugin/typescript.d.ts",
      "import": "./dist/cjs/macro-transform-plugin/typescript.js",
      "require": "./dist/cjs/macro-transform-plugin/typescript.js",
      "default": "./dist/cjs/macro-transform-plugin/typescript.js"
    },
    "./macro-transform-plugin/native": {
      "types": "./dist/cjs/macro-transform-plugin/native.d.ts",
      "import": "./dist/cjs/macro-transform-plugin/native.js",
      "require": "./dist/cjs/macro-transform-plugin/native.js",
      "default": "./dist/cjs/macro-transform-plugin/native.js"
    }
  },
  "scripts": {
    "build": "pnpm run build:cjs",
    "build:cjs": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.cjs.json",
    "test": "vitest run",
    "bench:large": "pnpm build && node benchmark/large-project.cjs",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@conf-ts/compiler": "workspace:*",
    "@conf-ts/macro-transformer": "workspace:*",
    "@jridgewell/remapping": "^2.3.5",
    "piscina": "^5.2.0"
  },
  "optionalDependencies": {
    "@conf-ts/compiler-native": "workspace:*",
    "@conf-ts/macro-transformer-native": "workspace:*"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^26.1.1",
    "@types/webpack": "^5.28.5",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "webpack": "^5.108.4"
  }
}
