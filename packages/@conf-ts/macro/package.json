{
  "name": "@conf-ts/macro",
  "version": "0.0.17",
  "description": "Macros for conf-ts.",
  "type": "commonjs",
  "author": {
    "name": "Zhongliang Wang",
    "email": "hello@zhongliang.wang",
    "url": "https://zhongliang.wang"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cryrivers/conf-ts"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^26.1.1",
    "@types/webpack-env": "^1.18.8",
    "prettier": "^3.9.5",
    "tsdown": "^0.22.7",
    "typescript": "^6.0.3"
  }
}
