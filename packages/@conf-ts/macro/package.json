{
  "name": "@conf-ts/macro",
  "version": "0.0.6",
  "description": "Macros for conf-ts.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cryrivers/conf-ts"
  },
  "main": "dist/cjs/index.js",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "require": "./dist/cjs/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/cjs/jsx-runtime.d.ts",
      "require": "./dist/cjs/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/cjs/jsx-dev-runtime.d.ts",
      "require": "./dist/cjs/jsx-dev-runtime.js"
    }
  },
  "types": "dist/cjs/index.d.ts",
  "scripts": {
    "build": "pnpm run build:cjs",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^25.7.0",
    "@types/webpack-env": "^1.18.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
