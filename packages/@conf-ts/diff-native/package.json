{
  "name": "@conf-ts/diff-native",
  "version": "0.0.17",
  "description": "Oxc-backed structural diff engine for conf-ts.",
  "author": {
    "name": "Zhongliang Wang",
    "email": "hello@zhongliang.wang",
    "url": "https://zhongliang.wang"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cryrivers/conf-ts"
  },
  "main": "index.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js"
    }
  },
  "types": "index.d.ts",
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "napi": {
    "binaryName": "diff-native",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-apple-darwin"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "format": "prettier . -w && cargo fmt",
    "prepublishOnly": "napi prepublish -t npm -p ../../native-bindings"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.3",
    "@types/node": "^26.1.1",
    "prettier": "^3.9.5"
  },
  "optionalDependencies": {
    "@conf-ts/diff-native-darwin-arm64": "workspace:*",
    "@conf-ts/diff-native-darwin-x64": "workspace:*",
    "@conf-ts/diff-native-linux-x64-gnu": "workspace:*",
    "@conf-ts/diff-native-linux-x64-musl": "workspace:*",
    "@conf-ts/diff-native-win32-x64-msvc": "workspace:*"
  }
}
