{
  "name": "@conf-ts/macro-transformer",
  "version": "0.0.14",
  "description": "Pre-evaluates conf-ts macros by rewriting source text, using the TypeScript compiler API.",
  "author": {
    "name": "Zhongliang Wang",
    "email": "hello@zhongliang.wang",
    "url": "https://zhongliang.wang"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cryrivers/conf-ts"
  },
  "main": "dist/cjs/index.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/cjs/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "types": "dist/cjs/index.d.ts",
  "scripts": {
    "build": "pnpm run build:cjs",
    "build:cjs": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.cjs.json",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@conf-ts/compiler": "workspace:*",
    "@conf-ts/expr-core": "workspace:*",
    "magic-string": "^0.30.21",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@conf-ts/macro": "workspace:*",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^26.1.1",
    "prettier": "^3.9.5",
    "vitest": "^4.1.10"
  }
}
