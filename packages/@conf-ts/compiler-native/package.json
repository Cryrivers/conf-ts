{
  "name": "@conf-ts/compiler-native",
  "version": "0.0.12",
  "description": "Native Rust compiler for conf-ts.",
  "author": {
    "name": "Zhongliang Wang",
    "email": "hello@zhongliang.wang",
    "url": "https://zhongliang.wang"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cryrivers/conf-ts"
  },
  "main": "index.js",
  "browser": "browser.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js"
    },
    "./browser": {
      "types": "./index.d.ts",
      "import": "./browser.js",
      "default": "./browser.js"
    }
  },
  "types": "index.d.ts",
  "files": [
    "index.d.ts",
    "index.js",
    "browser.js",
    "compiler-native.wasi.cjs",
    "compiler-native.wasi-browser.js",
    "compiler-native.wasm32-wasi.wasm",
    "wasi-worker.mjs",
    "wasi-worker-browser.mjs"
  ],
  "napi": {
    "binaryName": "compiler-native",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-apple-darwin",
      "wasm32-wasip1-threads"
    ]
  },
  "engines": {
    "node": ">= 12.22.0 < 13 || >= 14.17.0 < 15 || >= 15.12.0 < 16 || >= 16.0.0"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "pnpm run build:native && pnpm run build:wasi",
    "build:native": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:wasi": "napi build --platform --release --target wasm32-wasip1-threads && node ../scripts/finalize-wasi-browser.mjs",
    "test:wasi": "node --test ./test/wasi.test.cjs",
    "format:prettier": "prettier . -w && cargo fmt && taplo format",
    "lint": "oxlint .",
    "prepublishOnly": "napi prepublish -t npm -p ../../native-bindings",
    "preversion": "napi build --platform && git add .",
    "version": "napi version"
  },
  "dependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@napi-rs/wasm-runtime": "^1.1.6",
    "@napi-rs/cli": "^3.7.3"
  },
  "devDependencies": {
    "@conf-ts/compiler": "workspace:*",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^26.1.1",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.5",
    "tinybench": "^6.0.2",
    "tsx": "^4.23.1",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  },
  "optionalDependencies": {
    "@conf-ts/compiler-native-darwin-arm64": "workspace:*",
    "@conf-ts/compiler-native-darwin-x64": "workspace:*",
    "@conf-ts/compiler-native-linux-x64-gnu": "workspace:*",
    "@conf-ts/compiler-native-linux-x64-musl": "workspace:*",
    "@conf-ts/compiler-native-win32-x64-msvc": "workspace:*"
  }
}
