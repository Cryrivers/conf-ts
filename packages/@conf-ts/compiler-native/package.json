{
  "name": "@conf-ts/compiler-native",
  "version": "0.0.16",
  "description": "Oxc-backed native compiler for conf-ts.",
  "author": {
    "name": "Zhongliang Wang",
    "email": "hello@zhongliang.wang",
    "url": "https://zhongliang.wang"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cryrivers/conf-ts"
  },
  "main": "index.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js"
    }
  },
  "types": "index.d.ts",
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "napi": {
    "binaryName": "compiler-native",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-apple-darwin"
    ]
  },
  "engines": {
    "node": ">= 12.22.0 < 13 || >= 14.17.0 < 15 || >= 15.12.0 < 16 || >= 16.0.0"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "format": "prettier . -w && cargo fmt",
    "lint": "oxlint .",
    "prepublishOnly": "napi prepublish -t npm -p ../../native-bindings",
    "preversion": "pnpm run build:debug && git add .",
    "version": "napi version"
  },
  "devDependencies": {
    "@conf-ts/compiler": "workspace:*",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@napi-rs/cli": "^3.7.3",
    "@types/node": "^26.1.1",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.5",
    "tinybench": "^6.0.2",
    "tsx": "^4.23.1",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  },
  "optionalDependencies": {
    "@conf-ts/compiler-native-darwin-arm64": "workspace:*",
    "@conf-ts/compiler-native-darwin-x64": "workspace:*",
    "@conf-ts/compiler-native-linux-x64-gnu": "workspace:*",
    "@conf-ts/compiler-native-linux-x64-musl": "workspace:*",
    "@conf-ts/compiler-native-win32-x64-msvc": "workspace:*"
  }
}
