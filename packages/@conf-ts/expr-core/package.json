{
  "name": "@conf-ts/expr-core",
  "version": "0.0.14",
  "description": "Shared expression lexer, parser, and AST types for conf-ts",
  "keywords": [],
  "license": "MIT",
  "author": {
    "name": "Zhongliang Wang",
    "email": "hello@zhongliang.wang",
    "url": "https://zhongliang.wang"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cryrivers/conf-ts"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown --minify",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "dev": "tsdown --watch"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "prettier": "^3.9.5",
    "tsdown": "^0.22.7",
    "typescript": "^6.0.3"
  }
}
