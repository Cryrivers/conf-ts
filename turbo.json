{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "target/**", "*.node"]
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false
    },
    "test#@conf-ts/compiler-native": {
      "dependsOn": [],
      "cache": false
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "format": {
      "cache": false
    }
  }
}
